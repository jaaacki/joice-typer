# Copy to packaging/macos/release.env.local and fill in your real values.

# Developer ID identity used to sign the release app bundle and archive.
MACOS_CODESIGN_IDENTITY="Developer ID Application: Example, Inc. (TEAMID)"

# notarytool profile name already configured on the release machine.
MACOS_NOTARYTOOL_PROFILE="joicetyper-notary"

# Public appcast base URL, for example the GitHub Releases download URL prefix.
MACOS_APPCAST_BASE_URL="https://github.com/jaaacki/joice-typer/releases/download/v1.1.3"

# Sparkle public EdDSA key embedded in the app plist.
MACOS_SPARKLE_PUBLIC_ED_KEY="PUBLIC_KEY_HERE"

# Path to the Sparkle private key file used for signing update archives.
MACOS_SPARKLE_PRIVATE_KEY_FILE="/absolute/path/to/sparkle.private"

# Optional local Sparkle distribution archive path.
# If omitted, set MACOS_SPARKLE_DOWNLOAD_URL instead.
MACOS_SPARKLE_ARCHIVE_PATH="/absolute/path/to/Sparkle-2.x.tar.xz"

# Optional fallback download URL for Sparkle release tools/framework.
MACOS_SPARKLE_DOWNLOAD_URL="https://github.com/sparkle-project/Sparkle/releases/download/2.6.4/Sparkle-2.6.4.tar.xz"
