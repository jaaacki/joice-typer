# MSIX identity values from Microsoft Partner Center.
#
# Copy this file to identity.local.env and fill in the values from
# Partner Center → Apps and games → <your app> → Product identity.
# identity.local.env is gitignored.
#
# All four values are stable across versions and never change after the
# first submission.

WINDOWS_MSIX_IDENTITY_NAME=12345JoiceTyper.JoiceTyper
WINDOWS_MSIX_PUBLISHER=CN=ABCDEF12-3456-7890-ABCD-EF1234567890
WINDOWS_MSIX_PUBLISHER_DISPLAY_NAME=JoiceTyper
WINDOWS_MSIX_DISPLAY_NAME=JoiceTyper
